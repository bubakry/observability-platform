# Environment variables for the AWS Enterprise Observability Platform.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your real values
#   set -a && source .env && set +a
#   terraform init
#   terraform apply
#
# .env is gitignored. Never commit real values.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# 12-digit AWS account ID. Terraform checks this against the active caller identity.
export TF_VAR_aws_account_id=""

# ---------------------------------------------------------------------------
# Recommended
# ---------------------------------------------------------------------------

# Named AWS CLI profile. Leave empty to use the default credential chain
# (env vars, instance profile, default profile).
export TF_VAR_aws_profile=""

# Email address subscribed to the SNS alarm topic. Empty disables subscription.
export TF_VAR_alarm_email=""

# Tag values that should not live in source control.
export TF_VAR_owner=""
export TF_VAR_cost_center=""

# ---------------------------------------------------------------------------
# Optional overrides — defaults in variables.tf are sensible for portfolio use
# ---------------------------------------------------------------------------

# export TF_VAR_aws_region="us-east-1"
# export TF_VAR_environment="portfolio"
# export TF_VAR_project_name="aws-enterprise-observability"

# Lock public ALB ingress to known CIDRs. JSON list syntax.
# export TF_VAR_allowed_alb_ingress_cidrs='["203.0.113.0/24"]'

# Optional ACM certificate ARN. When set, the ALB serves HTTPS and redirects HTTP to 443.
# export TF_VAR_alb_certificate_arn="arn:aws:acm:us-east-1:123456789012:certificate/abcd-1234"

# ECS service autoscaling targets.
# export TF_VAR_ecs_autoscaling_min_capacity="2"
# export TF_VAR_ecs_autoscaling_max_capacity="6"
# export TF_VAR_ecs_autoscaling_cpu_target="60"
# export TF_VAR_ecs_autoscaling_memory_target="70"

# OpenSearch and Grafana hardening knobs.
# export TF_VAR_opensearch_instance_count="2"
# export TF_VAR_opensearch_create_service_linked_role="false"
# export TF_VAR_grafana_kms_key_deletion_window_in_days="30"

# Production hardening toggles.
# export TF_VAR_ecr_image_tag_mutability="IMMUTABLE"
# export TF_VAR_ecr_force_delete="false"
# export TF_VAR_enable_alb_deletion_protection="true"
# export TF_VAR_log_retention_days="30"

# Grant Grafana admin access to specific IAM Identity Center principals.
# export TF_VAR_grafana_admin_user_ids='["user-id-1","user-id-2"]'
# export TF_VAR_grafana_admin_group_ids='["group-id-1"]'

# Flip true only on accounts that have never used Amazon OpenSearch Service.
# export TF_VAR_opensearch_create_service_linked_role="false"
